{% extends "base.html.tera" %}

{% block title %}Assessment Report - Rheumatology Assessment{% endblock %}

{% block content %}
<div class="card">
  <div class="report-header">
    <h1>Rheumatology Assessment Report</h1>
    <span class="activity-badge activity-{{ activity_level }}">{{ activity_label }}</span>
  </div>

  <div class="score-display">{{ activity_score }}%</div>
  <div class="score-label">Composite Disease Activity Score</div>

  <p style="text-align: center; margin-top: 0.5rem; color: var(--gray-500); font-size: 0.875rem;">
    Assessment ID: {{ id }} | Generated: {{ timestamp }}
  </p>
</div>

<!-- DAS28 Section -->
<div class="card">
  <h2>DAS28 Classification</h2>
  {% if das28_score %}
    <div style="display: flex; align-items: center; gap: 1rem;">
      <div style="font-size: 2rem; font-weight: 700;">{{ das28_score }}</div>
      <span class="das28-badge das28-{{ das28_category }}">{{ das28_category | capitalize }}</span>
    </div>
  {% else %}
    <p style="color: var(--gray-500);">DAS28 score not provided.</p>
  {% endif %}
</div>

<!-- Patient Summary -->
<div class="card">
  <h2>Patient Summary</h2>
  <div class="form-row">
    <div>
      <strong>Patient:</strong> {{ data.patientInformation.patientName | default(value="Not provided") }}
    </div>
    <div>
      <strong>Diagnosis:</strong> {{ data.patientInformation.diagnosis | default(value="Not provided") }}
    </div>
  </div>
  <div class="form-row" style="margin-top: 0.5rem;">
    <div>
      <strong>Assessment Date:</strong> {{ data.patientInformation.assessmentDate | default(value="Not provided") }}
    </div>
    <div>
      <strong>Rheumatologist:</strong> {{ data.patientInformation.rheumatologistName | default(value="Not provided") }}
    </div>
  </div>
</div>

<!-- Additional Flags -->
{% if additional_flags | length > 0 %}
<div class="card">
  <h2>Flagged Issues</h2>
  <div class="flags-section">
    {% for flag in additional_flags %}
    <div class="flag-item flag-{{ flag.priority }}">
      <div class="flag-meta">
        <span class="concern-badge concern-{{ flag.priority }}">{{ flag.priority | upper }}</span>
        &nbsp; {{ flag.category }}
      </div>
      <div>{{ flag.message }}</div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

<!-- Rheumatology Rules -->
{% if fired_rules | length > 0 %}
<div class="card">
  <h2>Disease Activity Analysis</h2>
  <table class="rules-table">
    <thead>
      <tr>
        <th>Rule</th>
        <th>Category</th>
        <th>Description</th>
        <th>Concern</th>
      </tr>
    </thead>
    <tbody>
      {% for rule in fired_rules %}
      <tr>
        <td>{{ rule.id }}</td>
        <td>{{ rule.category }}</td>
        <td>{{ rule.description }}</td>
        <td><span class="concern-badge concern-{{ rule.concernLevel }}">{{ rule.concernLevel | upper }}</span></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}

<!-- Clinician Notes -->
{% if data.clinicalReview.clinicianNotes %}
<div class="card">
  <h2>Clinician Notes</h2>
  <div class="form-group">
    <p>{{ data.clinicalReview.clinicianNotes }}</p>
  </div>
</div>
{% endif %}

<!-- Actions -->
<div class="card" style="text-align: center;">
  <a href="/" class="btn btn-primary">New Assessment</a>
  <a href="/dashboard" class="btn btn-secondary" style="margin-left: 0.5rem;">View Dashboard</a>
  <button onclick="window.print()" class="btn btn-secondary" style="margin-left: 0.5rem;">Print Report</button>
</div>
{% endblock %}
