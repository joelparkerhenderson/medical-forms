<div class="step-nav">
  {% if prev_step %}
    <a href="/assessment/{{ id }}/step/{{ prev_step }}" class="btn btn-secondary">Previous</a>
  {% endif %}
  {% if next_step %}
    <button type="submit" class="btn btn-primary">Next</button>
  {% else %}
    <button type="submit" class="btn btn-success">Submit Assessment</button>
  {% endif %}
</div>
