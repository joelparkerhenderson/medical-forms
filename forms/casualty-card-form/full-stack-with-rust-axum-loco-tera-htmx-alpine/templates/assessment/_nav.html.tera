<div class="step-nav">
    {% if prev_step %}
        <a href="/assessment/{{ id }}/step/{{ prev_step }}" class="btn btn-secondary">&larr; Previous</a>
    {% else %}
        <span></span>
    {% endif %}

    {% if next_step %}
        <button type="submit" class="btn btn-primary">Save &amp; Continue &rarr;</button>
    {% else %}
        <button type="submit" class="btn btn-success">Submit Assessment</button>
    {% endif %}
</div>
