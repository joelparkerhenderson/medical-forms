<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{% block title %}{{ form_title | default(value="Pre-operative Assessment by Clinician") }}{% endblock %}</title>
  <script defer src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    [x-cloak] { display: none !important; }
    .card { @apply bg-white rounded-lg shadow-sm border border-slate-200 p-6 mb-4; }
    .field-label { @apply block text-sm font-medium text-slate-700 mb-1; }
    .field-input { @apply block w-full rounded-md border-slate-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm p-2 border; }
    .btn-primary { @apply inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-md text-sm font-medium hover:bg-blue-700; }
  </style>
</head>
<body hx-boost="true">
  <div class="min-h-screen bg-slate-50 text-slate-900">
    <header class="bg-blue-700 text-white p-4">
      <div class="max-w-5xl mx-auto">
        <h1 class="text-2xl font-bold">Pre-operative Assessment by Clinician</h1>
        <p class="text-sm opacity-90">
          UK NHS–aligned ASA grading + composite perioperative risk.
          Single-page clinician wizard.
        </p>
      </div>
    </header>
    <main class="max-w-5xl mx-auto p-4">
      {% block content %}{% endblock %}
    </main>
  </div>
</body>
</html>
