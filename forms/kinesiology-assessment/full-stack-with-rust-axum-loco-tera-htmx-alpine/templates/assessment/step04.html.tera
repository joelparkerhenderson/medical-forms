<div class="card">
<h2>Range of Motion</h2>
    <p class="hint">Rate each movement range (1 = Severely Restricted, 5 = Full / Normal Range).</p>

    <div class="form-row">
      <div class="form-group">
        <label for="cervical_flexion">Cervical Flexion</label>
        <select id="cervical_flexion" name="range_of_motion.cervical_flexion">
          <option value="">-- Select --</option>
          <option value="1" {% if range_of_motion.cervicalFlexion == 1 %}selected{% endif %}>1 - Severely Restricted</option>
          <option value="2" {% if range_of_motion.cervicalFlexion == 2 %}selected{% endif %}>2 - Moderately Restricted</option>
          <option value="3" {% if range_of_motion.cervicalFlexion == 3 %}selected{% endif %}>3 - Mildly Restricted</option>
          <option value="4" {% if range_of_motion.cervicalFlexion == 4 %}selected{% endif %}>4 - Near Normal</option>
          <option value="5" {% if range_of_motion.cervicalFlexion == 5 %}selected{% endif %}>5 - Full Range</option>
        </select>
      </div>
      <div class="form-group">
        <label for="cervical_rotation">Cervical Rotation</label>
        <select id="cervical_rotation" name="range_of_motion.cervical_rotation">
          <option value="">-- Select --</option>
          <option value="1" {% if range_of_motion.cervicalRotation == 1 %}selected{% endif %}>1 - Severely Restricted</option>
          <option value="2" {% if range_of_motion.cervicalRotation == 2 %}selected{% endif %}>2 - Moderately Restricted</option>
          <option value="3" {% if range_of_motion.cervicalRotation == 3 %}selected{% endif %}>3 - Mildly Restricted</option>
          <option value="4" {% if range_of_motion.cervicalRotation == 4 %}selected{% endif %}>4 - Near Normal</option>
          <option value="5" {% if range_of_motion.cervicalRotation == 5 %}selected{% endif %}>5 - Full Range</option>
        </select>
      </div>
    </div>

    <div class="form-row">
