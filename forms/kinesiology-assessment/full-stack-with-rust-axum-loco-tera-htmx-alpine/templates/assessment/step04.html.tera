        <label for="shoulder_flexion">Shoulder Flexion</label>
        <select id="shoulder_flexion" name="range_of_motion.shoulder_flexion">
          <option value="">-- Select --</option>
          <option value="1" {% if range_of_motion.shoulderFlexion == 1 %}selected{% endif %}>1 - Severely Restricted</option>
          <option value="2" {% if range_of_motion.shoulderFlexion == 2 %}selected{% endif %}>2 - Moderately Restricted</option>
          <option value="3" {% if range_of_motion.shoulderFlexion == 3 %}selected{% endif %}>3 - Mildly Restricted</option>
          <option value="4" {% if range_of_motion.shoulderFlexion == 4 %}selected{% endif %}>4 - Near Normal</option>
          <option value="5" {% if range_of_motion.shoulderFlexion == 5 %}selected{% endif %}>5 - Full Range</option>
        </select>
      </div>
      <div class="form-group">
        <label for="shoulder_abduction">Shoulder Abduction</label>
        <select id="shoulder_abduction" name="range_of_motion.shoulder_abduction">
          <option value="">-- Select --</option>
          <option value="1" {% if range_of_motion.shoulderAbduction == 1 %}selected{% endif %}>1 - Severely Restricted</option>
          <option value="2" {% if range_of_motion.shoulderAbduction == 2 %}selected{% endif %}>2 - Moderately Restricted</option>
          <option value="3" {% if range_of_motion.shoulderAbduction == 3 %}selected{% endif %}>3 - Mildly Restricted</option>
          <option value="4" {% if range_of_motion.shoulderAbduction == 4 %}selected{% endif %}>4 - Near Normal</option>
          <option value="5" {% if range_of_motion.shoulderAbduction == 5 %}selected{% endif %}>5 - Full Range</option>
        </select>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="lumbar_flexion">Lumbar Flexion</label>
        <select id="lumbar_flexion" name="range_of_motion.lumbar_flexion">
          <option value="">-- Select --</option>
          <option value="1" {% if range_of_motion.lumbarFlexion == 1 %}selected{% endif %}>1 - Severely Restricted</option>
          <option value="2" {% if range_of_motion.lumbarFlexion == 2 %}selected{% endif %}>2 - Moderately Restricted</option>
