          <option value="4" {% if range_of_motion.lumbarFlexion == 4 %}selected{% endif %}>4 - Near Normal</option>
          <option value="5" {% if range_of_motion.lumbarFlexion == 5 %}selected{% endif %}>5 - Full Range</option>
        </select>
      </div>
      <div class="form-group">
        <label for="lumbar_extension">Lumbar Extension</label>
        <select id="lumbar_extension" name="range_of_motion.lumbar_extension">
          <option value="">-- Select --</option>
          <option value="1" {% if range_of_motion.lumbarExtension == 1 %}selected{% endif %}>1 - Severely Restricted</option>
          <option value="2" {% if range_of_motion.lumbarExtension == 2 %}selected{% endif %}>2 - Moderately Restricted</option>
