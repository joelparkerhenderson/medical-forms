      <div class="form-group">
        <label for="hip_flexion">Hip Flexion</label>
        <select id="hip_flexion" name="range_of_motion.hip_flexion">
          <option value="">-- Select --</option>
          <option value="1" {% if range_of_motion.hipFlexion == 1 %}selected{% endif %}>1 - Severely Restricted</option>
          <option value="2" {% if range_of_motion.hipFlexion == 2 %}selected{% endif %}>2 - Moderately Restricted</option>
          <option value="3" {% if range_of_motion.hipFlexion == 3 %}selected{% endif %}>3 - Mildly Restricted</option>
          <option value="4" {% if range_of_motion.hipFlexion == 4 %}selected{% endif %}>4 - Near Normal</option>
          <option value="5" {% if range_of_motion.hipFlexion == 5 %}selected{% endif %}>5 - Full Range</option>
        </select>
      </div>
      <div class="form-group">
        <label for="knee_flexion">Knee Flexion</label>
        <select id="knee_flexion" name="range_of_motion.knee_flexion">
          <option value="">-- Select --</option>
          <option value="1" {% if range_of_motion.kneeFlexion == 1 %}selected{% endif %}>1 - Severely Restricted</option>
          <option value="2" {% if range_of_motion.kneeFlexion == 2 %}selected{% endif %}>2 - Moderately Restricted</option>
          <option value="3" {% if range_of_motion.kneeFlexion == 3 %}selected{% endif %}>3 - Mildly Restricted</option>
          <option value="4" {% if range_of_motion.kneeFlexion == 4 %}selected{% endif %}>4 - Near Normal</option>
          <option value="5" {% if range_of_motion.kneeFlexion == 5 %}selected{% endif %}>5 - Full Range</option>
