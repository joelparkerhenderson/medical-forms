#!/bin/sh
set -euf
top="$(git rev-parse --show-toplevel)"

mkdir_with_ai() (
  # dir="$1"
  mkdir -p "$1"
  cd "$1"
  touch index.md
  ln -sfn index.md README.md
  touch AGENTS.md
  test -f CLAUDE.md || echo "@AGENTS.md" > CLAUDE.md

)

mkdir_with_ai_planning() (
  # dir="$1"
  mkdir_with_ai "$1"
  cd "$1"
  touch plan.md
  touch tasks.md
)

dir="$top/forms/$1"
mkdir_with_ai_planning "$dir"

mkdir_with_ai "$dir/cargo-loco-generate"
mkdir_with_ai "$dir/doc"
mkdir_with_ai "$dir/fhir-r5"
mkdir_with_ai "$dir/sql-migrations"
mkdir_with_ai "$dir/xml-representations"

mkdir_with_ai_planning "$dir/front-end-form-with-html"
mkdir_with_ai_planning "$dir/front-end-form-with-svelte"
mkdir_with_ai_planning "$dir/front-end-dashboard-with-html"
mkdir_with_ai_planning "$dir/front-end-dashboard-with-svelte"
mkdir_with_ai_planning "$dir/full-stack-with-rust-axum-loco-tera-htmx-alpine"

rsync -av "$top/skel/" "$dir/"
